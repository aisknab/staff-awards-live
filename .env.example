NODE_ENV=production
HOST=127.0.0.1
PORT=8787
PUBLIC_ORIGIN=https://awards.example.com

DATABASE_PATH=/var/lib/staff-awards/awards.sqlite
BACKUP_DIR=/var/backups/staff-awards
BACKUP_RETENTION_DAYS=14

APP_SECRET=replace-with-output-from-npm-run-create-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-output-from-npm-run-create-admin-hash

ADMIN_SESSION_HOURS=12
PARTICIPANT_SESSION_HOURS=18
DISPLAY_SESSION_HOURS=24
TRUST_LOOPBACK_PROXY=true
LOG_LEVEL=info
MAX_BODY_BYTES=32768
MASKED_MIN_VOTES=3
MASKED_MIN_INTERVAL_MS=2000
MASKED_MAX_DELAY_MS=5000
