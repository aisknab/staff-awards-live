{
  "name": "staff-awards-live",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted live staff awards voting with masked public tallies",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "NODE_ENV=test node --test --test-concurrency=1 tests/*.test.js",
    "migrate": "node src/migrate-cli.js",
    "create-secret": "node scripts/create-secret.js",
    "create-admin-hash": "node scripts/create-admin-hash.js",
    "backup": "node scripts/backup.js",
    "restore-check": "node scripts/restore-check.js",
    "seed": "node scripts/seed-demo.js",
    "simulate-event": "NODE_ENV=test node scripts/simulate-event.js"
  },
  "dependencies": {
    "qrcode": "1.5.4"
  }
}
